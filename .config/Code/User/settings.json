{
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "vscode-neovim.compositeKeys": {
    "jj": {
      "command": "vscode-neovim.escape"
    },
    "jk": {
      // Use lua to execute any logic
      "command": "vscode-neovim.lua",
      "args": [
        [
          "local code = require('vscode')",
          "code.action('vscode-neovim.escape')",
          "code.action('workbench.action.files.save')"
        ]
      ]
    }
  },
  "window.customTitleBarVisibility": "auto",
  "window.menuBarVisibility": "toggle",
  "window.titleBarStyle": "native",
  "files.autoSave": "off",
  "files.saveConflictResolution": "overwriteFileOnDisk",
  "editor.lineNumbers": "relative",
  "editor.fontSize": 17,
  "editor.fontFamily": "JetBrainsMono Nerd Font Mono",
  "editor.lineHeight": 22,
  "editor.letterSpacing": 0.2,
  "editor.fontLigatures": false,
  "editor.occurrencesHighlight": "off",

  "editor.smoothScrolling": true,
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.linkedEditing": true,
  "editor.tabCompletion": "on",
  "editor.quickSuggestions": {
    "strings": true
  },
  "eslint.enable": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.renderWhitespace": "none",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "on",
  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "search.exclude": {
    "**/vendor/{[^l],?[^ai]}*": true,
    "**/public/{[^i],?[^n]}*": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/_ide_helper.php": true,
    "**/composer.lock": true,
    "**/package-lock.json": true,
    "storage": true,
    ".phpunit.result.cache": true
  },
  "security.workspace.trust.startupPrompt": "never",
  "security.workspace.trust.enabled": false,
  "workbench.activityBar.location": "top",
  "workbench.startupEditor": "none",
  "workbench.iconTheme": "symbols",
  "workbench.layoutControl.enabled": true,
  "workbench.sideBar.location": "left",
  "workbench.navigationControl.enabled": false,
  "window.commandCenter": false,
  "workbench.colorTheme": "Gruvbox Material Dark",
  "gruvboxMaterial.darkContrast": "hard",
  "gruvboxMaterial.darkPalette": "original",
  "gruvboxMaterial.darkWorkbench": "high-contrast",
  "workbench.colorCustomizations": {
    "[Gruvbox Material Dark]": {
      "editor.background": "#1d2021",
      "editor.selectionBackground": "#504945cc",
      "editor.lineHighlightBackground": "#fff0",
      "editor.selectionHighlightBorder": "#fff0",
      "editor.findMatchBackground": "#d7992177",
      "activityBar.background": "#282828",
      "activityBarBadge.background": "#d79921",
      "titleBar.activeBackground": "#1d2021",
      "titleBar.border": "#1d2021",
      "statusBar.background": "#1d2021",
      "statusBar.border": "#282828",
      "statusBar.noFolderBackground": "#1d2021",
      "statusBar.debuggingBackground": "#cc241d",
      "scrollbarSlider.background": "#665c54aa",
      "scrollbarSlider.hoverBackground": "#928374aa",
      "scrollbarSlider.activeBackground": "#a89984aa"
    },
    "[Tokyo Night]": {
      "editor.background": "#11121D",
      "sideBar.background": "#0d0e17",
      "activityBar.background": "#0d0e17",
      "panel.background": "#0d0e17",
      "terminal.background": "#11121D",
      "editor.lineHighlightBackground": "#11121D",
      "editor.foreground": "#A0A8CD",
      "editorLineNumber.foreground": "#4A5057",
      "editor.findMatchBackground": "#95650D",
      "editor.findMatchHighlightBackground": "#3c435daa",
      "editor.findMatchBorder": "#fff0",
      "editor.selectionHighlightBorder": "#fff0"
    }
  },
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.showExitAlert": false,
  "terminal.integrated.rightClickBehavior": "copyPaste",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "emmet.excludeLanguages": ["markdown", "php"],
  "liveServer.settings.donotShowInfoMsg": true,
  "liveServer.settings.CustomBrowser": "chrome",
  "emmet.triggerExpansionOnTab": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "database-client.autoSync": true,
  "breadcrumbs.enabled": false,
  "remote.SSH.defaultExtensions": ["gitpod.gitpod-remote-ssh"],
  "remote.SSH.remotePlatform": {
    "freecodecam-learnsqlbyb-pzwuxagzx4n.vss.gitpod.io": "linux",
    "*.gitpod.io": "linux",
    "freecodecam-learnbashby-zp75vvgnqnu.vss.gitpod.io": "linux",
    "freecodecam-learnrelati-do4xb37hew0.vss.gitpod.io": "linux",
    "freecodecam-learnsqlbyb-qoobect7yxk.vss.gitpod.io": "linux"
  },
  "security.allowedUNCHosts": ["wsl.localhost"],
  "github.copilot.nextEditSuggestions.enabled": true,
  "tabnine.experimentalAutoImports": true,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  }
}