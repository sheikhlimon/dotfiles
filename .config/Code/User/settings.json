{
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "vscode-neovim.compositeKeys": {
    "jj": {
      "command": "vscode-neovim.escape"
    },
    "jk": {
      // Use lua to execute any logic
      "command": "vscode-neovim.lua",
      "args": [
        [
          "local code = require('vscode')",
          "code.action('vscode-neovim.escape')",
          "code.action('workbench.action.files.save')"
        ]
      ]
    }
  },
  // "window.zoomLevel": 0.1,
  "window.customTitleBarVisibility": "auto",
  "window.menuBarVisibility": "toggle",
  "window.titleBarStyle": "native",
  "files.autoSave": "off",
  "files.saveConflictResolution": "overwriteFileOnDisk",
  "editor.lineNumbers": "relative",
  "editor.fontSize": 18,
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  // "editor.fontLigatures": "'ss01','ss05','dlig'",
  "explorer.decorations.badges": false,
  "editor.occurrencesHighlight": "off",
  "editor.bracketPairColorization.enabled": false,
  "editor.smoothScrolling": true,
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.linkedEditing": true,
  "editor.tabCompletion": "on",
  "editor.stickyScroll.enabled": false,
  "editor.tabSize": 2,
  "editor.useTabStops": true,
  "editor.quickSuggestions": {
    "strings": true
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.renderWhitespace": "none",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "on",
  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "editor.hover.delay": 3000,
  "typescript.inlayHints.parameterNames.enabled": "none",
  "security.workspace.trust.startupPrompt": "never",
  "security.workspace.trust.enabled": false,
  "files.eol": "\n",
  "workbench.tree.indent": 10,
  "workbench.activityBar.location": "top",
  "workbench.startupEditor": "none",
  "workbench.iconTheme": "catppuccin-mocha",
  "workbench.productIconTheme": "icons-carbon",
  "workbench.layoutControl.enabled": true,
  "workbench.sideBar.location": "left",
  "workbench.navigationControl.enabled": false,
  "window.autoDetectColorScheme": true,
  "workbench.colorCustomizations": {
    "[Rosé Pine Moon (no italics)]": {
      "editor.lineHighlightBackground": "#fff0",
      "editor.lineHighlightBorder": "#fff0",
      "editor.findMatchBorder": "#fff0",
      "editor.selectionHighlightBorder": "#fff0",
      "editor.findMatchBackground": "#95650D",
      "editor.findMatchHighlightBackground": "#546E7A63",
      "editor.selectionBackground": "#546E7A60",
      "editor.background": "#191724",
      "editorCursor.foreground": "#FFF",
      "editorCursor.background": "#0D1116",
      "sideBar.background": "#191724",
      "activityBar.background": "#191724",
      "panel.background": "#191724",
      "terminal.background": "#191724",
      "editorGutter.background": "#191724"
    }
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "punctuation.definition.parameters.begin",
          "punctuation.definition.parameters.end",
          "punctuation.definition.arguments.begin",
          "punctuation.definition.arguments.end",
          "punctuation.section.group.begin",
          "punctuation.section.group.end",
          // "meta.brace.round",
          "meta.brace.curly",
          "meta.brace.square",
          "punctuation.definition.block",
          "punctuation.section.block.begin",
          "punctuation.section.block.end"
        ],
        "settings": {
          "foreground": "#9ccfd8"
        }
      }
    ]
  },
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.showExitAlert": false,
  "terminal.integrated.rightClickBehavior": "copyPaste",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "emmet.excludeLanguages": ["markdown", "php"],
  "liveServer.settings.donotShowInfoMsg": true,
  "liveServer.settings.CustomBrowser": "chrome",
  "emmet.triggerExpansionOnTab": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "database-client.autoSync": true,
  "breadcrumbs.enabled": false,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "search.exclude": {
    "**/vendor/{[^l],?[^ai]}*": true,
    "**/public/{[^i],?[^n]}*": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/_ide_helper.php": true,
    "**/composer.lock": true,
    "**/package-lock.json": true,
    "storage": true,
    ".phpunit.result.cache": true
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "workbench.preferredDarkColorTheme": "Noir Rosé Pine Grey"
}
