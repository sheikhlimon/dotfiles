#!/bin/sh

# rofi theme
theme="$HOME/.config/rofi/main_without_icons.rasi"

get_options() {
  echo "¯ºÇ Poweroff"
  echo "¯ºâ Reboot"
  echo "¯ª« Hibernate"
}

main() {

  # get choice from rofi
  choice=$( (get_options) | rofi -dmenu -i -fuzzy -p "¯ºÇ" -theme "$theme")

  # run the selected command
  case $choice in
  '¯ºÇ Poweroff')
    systemctl poweroff
    ;;
  '¯ºâ Reboot')
    systemctl reboot
    ;;
  '¯ªú Suspend')
    systemctl suspend
    ;;
  esac

  # done
  set -e
}

main &

exit 0
